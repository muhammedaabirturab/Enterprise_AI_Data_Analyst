# --- Core ---
APP_NAME=Veridian
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# --- Database ---
# SQLite by default. Swap to a PostgreSQL URL later, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/veridian
DATABASE_URL=sqlite:///./veridian.db

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=50
STORAGE_DIR=./storage

# --- Optional: real LLM backend for AI Chat / Insights ---
# If left blank, Veridian uses its built-in offline statistical AI engine.
# Supported providers: "anthropic" or "openai"
LLM_PROVIDER=
LLM_API_KEY=
